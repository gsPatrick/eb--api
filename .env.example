# Server
NODE_ENV=development
PORT=3000
APP_API_PREFIX=/api
# Reverse proxy hops (1 = nginx/docker; false = local dev)
TRUST_PROXY=false

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eb_services
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# i18n — default locale for responses when Accept-Language is absent
DEFAULT_LOCALE=pt

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS — * or all = any domain; or comma-separated list to restrict
CORS_ORIGINS=*

# iCal sync (Airbnb / external calendars)
ICAL_SYNC_ENABLED=true
ICAL_SYNC_CRON=0 * * * *
ICAL_FETCH_TIMEOUT_MS=15000

# Mail (console = simulated; smtp/sendgrid ready)
MAIL_ENABLED=true
MAIL_DRIVER=console
MAIL_FROM=noreply@ebservices.local

# WebSocket
SOCKET_PATH=/socket.io

# Geofence — max distance (meters) for provider check-in/check-out
GEOFENCE_MAX_DISTANCE_METERS=200

# Default admin — created automatically on startup if missing
ADMIN_BOOTSTRAP=true
ADMIN_NAME=EB Admin
ADMIN_EMAIL=admin@ebservices.local
ADMIN_PASSWORD=Admin@EB2026
ADMIN_LOCALE=pt
